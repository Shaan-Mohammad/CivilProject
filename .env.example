# ─── CivilDraft Pro Environment Configuration ────────────────────────
# Copy this file to .env and fill in the values

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── NextAuth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CivilDraft Pro"

# ─── Storage ─────────────────────────────────────────────────────────
# Options: "local" | "s3" (S3 not implemented yet)
STORAGE_PROVIDER="local"

# ─── S3 (Future - uncomment when migrating to S3) ────────────────────
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# ─── Admin Setup ─────────────────────────────────────────────────────
# Default admin credentials (used by seed script)
ADMIN_EMAIL="admin@civildraftpro.com"
ADMIN_PASSWORD="Admin@123456"
